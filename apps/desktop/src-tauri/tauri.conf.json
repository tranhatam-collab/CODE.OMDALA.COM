{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "productName": "OMCODE",
  "version": "0.1.0-alpha",
  "identifier": "com.omdala.code",
  "build": {
    "beforeDevCommand": "echo 'Vite dev running'",
    "beforeBuildCommand": "pnpm build:renderer",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist/renderer"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "identifier": "com.omdala.code"
  },
  "app": {
    "windows": [
      {
        "fullscreen": false,
        "height": 600,
        "resizable": true,
        "title": "OMCODE",
        "width": 800
      }
    ],
    "security": {
      "csp": null
    }
  }
}
