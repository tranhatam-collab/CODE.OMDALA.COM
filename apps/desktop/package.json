{
  "name": "@omcode/desktop",
  "version": "0.1.0-alpha",
  "private": true,
  "main": "dist/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"pnpm build:main\" \"pnpm build:preload\" \"pnpm build:renderer\" \"wait-on dist/main/index.js && electron dist/main/index.js\"",
    "build": "pnpm build:main && pnpm build:preload && pnpm build:renderer",
    "build:main": "tsc -p src/main/tsconfig.json",
    "build:preload": "tsc -p src/preload/tsconfig.json",
    "build:renderer": "vite build",
    "lint": "biome check src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@omcode/i18n": "workspace:*",
    "@omcode/schemas": "workspace:*",
    "@omcode/config": "workspace:*",
    "@omcode/ui": "workspace:*",
    "@omcode/command-policies": "workspace:*",
    "@omcode/git-tools": "workspace:*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.1.0",
    "electron": "^33.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^0.28.0",
    "wait-on": "^8.0.0"
  }
}
