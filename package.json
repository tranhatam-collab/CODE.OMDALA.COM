    "clean": "turbo run clean && rm -rf node_modules",
    "bootstrap:mac": "bash scripts/bootstrap-mac.sh"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "devDependencies": {
    "turbo": "^2.9.1"
  }
}
