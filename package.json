{
  "name": "omcode",
  "private": true,
  "version": "0.0.1",
  "description": "OMCODE — AI-native coding workspace for Mac developers",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
