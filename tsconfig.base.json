{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "incremental": true,
    "paths": {
      "@omcode/config": ["./packages/config/src"],
      "@omcode/schemas": ["./packages/schemas/src"],
      "@omcode/i18n": ["./packages/i18n/src"],
      "@omcode/ui": ["./packages/ui/src"],
      "@omcode/prompts": ["./packages/prompts/src"],
      "@omcode/command-policies": ["./packages/command-policies/src"],
      "@omcode/git-tools": ["./packages/git-tools/src"],
      "@omcode/mcp-clients": ["./packages/mcp-clients/src"],
      "@omcode/ai-gateway-sdk": ["./packages/ai-gateway-sdk/src"],
      "@omcode/shared": ["./packages/shared/src"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
